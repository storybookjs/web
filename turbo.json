{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "ALGOLIA_API_KEY",
    "ANALYZE",
    "SENTRY_KEY",
    "CONTEXT",
    "GCP_CREDENTIALS",
    "GITHUB_STORYBOOK_BOT_PAT",
    "NEXT_PUBLIC_ALGOLIA_API_KEY",
    "NEXT_PUBLIC_BASE_PATH",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NODE_ENV",
    "SKIP_IP_HASH",
    "SLOW_GRAPHQL_CLIENT",
    "URL"
  ],
  "tasks": {
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "generate-redirects": {
      "inputs": [
        "./apps/frontpage/scripts/raw-redirects",
        "./apps/frontpage/scripts/static-redirects"
      ],
      "outputs": ["./apps/frontpage/public/_redirects"],
      "cache": false
    },
    "generate-versions": {
      "cache": false,
      "outputs": ["./apps/frontpage/generated-versions.json"]
    },
    "fetch-docs": {
      "cache": false
    },
    "storybook": {
      "dependsOn": ["^storybook"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    },
    "build": {
      "dependsOn": ["fetch-docs", "generate-redirects", "generate-versions", "^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "storybook-static/**"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        "./apps/frontpage/generated-versions.json",
        "./apps/frontpage/content/docs/**",
        "./apps/frontpage/content/snippets/**",
        "./apps/frontpage/public/docs-assets/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "test": {}
  }
}
